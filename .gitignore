```gitignore
# Nuxt.js build outputs
.output/
.dist/
.nuxt/
.cache/

# Node dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/

# Python (if present)
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
venv/
.venv/
.env

# Build artifacts
dist/
build/
target/
*.exe
*.dll
*.so
*.a
*.o
*.obj
*.out

# Coverage
coverage/
htmlcov/
.coverage

# Compressed files
*.zip
*.gz
*.tar
*.tgz
*.bz2
*.xz
*.7z
*.rar
*.zst
*.lz4
*.lzh
*.cab
*.arj
*.rpm
*.deb
*.Z
*.lz
*.lzo
*.tar.gz
*.tar.bz2
*.tar.xz
*.tar.zst
```